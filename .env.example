# === TABARA GROUP ENV VARIABLES === #

# 1. Crée un compte gratuitement sur resend.com
# 2. Va dans "API Keys" et génère une nouvelle clé
# 3. Renomme ce fichier en ".env.local" ou configure les variables dans Ansible/Docker
# 4. Copie-colle ta clé ci-dessous :

RESEND_API_KEY=re_YOUR_KEY_HERE

# Configuration de l'application
PORT=3000
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://tabaragroup.sn